{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "..",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "paths": {
      "@agent": ["./src/index.ts"],
      "@agent/*": ["./src/*"],
      "@worldsmith/motion-kit": ["../packages/motion-kit/src/index.ts"],
      "@worldsmith/motion-kit/*": ["../packages/motion-kit/src/*"],
      "@worldsmith/ui-kit": ["../packages/ui-kit/src/index.ts"],
      "@worldsmith/ui-kit/*": ["../packages/ui-kit/src/*"],
      "@worldsmith/entity-core": ["../packages/entity-core/src/index.ts"],
      "@worldsmith/entity-core/*": ["../packages/entity-core/src/*"],
      "@worldsmith/plugin-sdk": ["../packages/plugin-sdk/src/index.ts"],
      "@worldsmith/plugin-sdk/*": ["../packages/plugin-sdk/src/*"],
      "@worldsmith/canvas-engine": ["../packages/canvas-engine/src/index.ts"],
      "@worldsmith/canvas-engine/*": ["../packages/canvas-engine/src/*"],
      "@worldsmith/font-kit": ["../packages/font-kit/src/index.ts"],
      "@worldsmith/font-kit/*": ["../packages/font-kit/src/*"],
      "@worldsmith/agent-core": ["../packages/agent-core/src/index.ts"],
      "@worldsmith/agent-core/*": ["../packages/agent-core/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
