{
  "name": "worldsmith",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "cd worldsmith-server && npm run dev",
    "server:start": "cd worldsmith-server && npm run start",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "clean": "node scripts/clean.js light",
    "clean:deep": "node scripts/clean.js deep",
    "clean:full": "node scripts/clean.js full",
    "build:wasm": "wasm-pack build ./tactical-engine --target bundler --out-dir pkg --scope worldsmith",
    "build:core": "wasm-pack build ./worldsmith-core --target bundler --out-dir pkg --scope worldsmith -- --features wasm",
    "build:wasm-all": "npm run build:wasm && npm run build:core",
    "build:web": "npm run build:wasm-all && vue-tsc -b && vite build",
    "build": "npm run build:wasm-all && vue-tsc -b && vite build",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.7",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tiptap/extension-mention": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/suggestion": "^3.24.0",
    "@tiptap/vue-3": "^3.22.5",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "@windfonts/chinese-fonts": "^1.0.22",
    "@worldsmith/agent-core": "file:./packages/agent-core",
    "@worldsmith/canvas-engine": "file:./packages/canvas-engine",
    "@worldsmith/core": "file:./worldsmith-core/pkg",
    "@worldsmith/entity-core": "file:./packages/entity-core",
    "@worldsmith/font-kit": "file:./packages/font-kit",
    "@worldsmith/motion-kit": "file:./packages/motion-kit",
    "@worldsmith/plugin-sdk": "file:./packages/plugin-sdk",
    "@worldsmith/tactical-engine": "file:./tactical-engine/pkg",
    "@worldsmith/ui-kit": "file:./packages/ui-kit",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dexie": "^4.4.2",
    "docx": "^9.6.1",
    "dompurify": "^3.4.3",
    "echarts": "^6.1.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout": "^0.6.1",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-shortest-path": "^2.1.0",
    "js-yaml": "^4.1.1",
    "jszip": "^3.10.1",
    "lucide-vue-next": "^0.577.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "naive-ui": "^2.44.1",
    "pdfjs-dist": "^5.7.284",
    "pinia": "^3.0.4",
    "sigma": "^3.0.3",
    "turndown": "^7.2.4",
    "vis-timeline": "^8.5.0",
    "vue": "^3.5.32",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/vue3-vite": "^8.6.18",
    "@tauri-apps/cli": "^2.11.2",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.2",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "storybook": "^8.6.18",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.2.6",
    "vue-tsc": "^3.2.7"
  }
}
